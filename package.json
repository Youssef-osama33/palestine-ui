{
  "name": "palestine-ui",
  "version": "1.0.1",
  "description": "A design system for Palestine — colors, icons, kuffiyeh patterns, and fonts for developers building Palestine-related projects.",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./tokens": "./dist/tokens/tokens.css",
    "./tokens.css": "./dist/tokens/tokens.css",
    "./icons": {
      "import": "./dist/icons/index.esm.js",
      "require": "./dist/icons/index.cjs.js",
      "types": "./dist/icons/index.d.ts"
    },
    "./icons/*.svg": "./dist/icons/svg/*.svg"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "dev": "node scripts/build.js --watch",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "palestine",
    "design-system",
    "ui",
    "icons",
    "kuffiyeh",
    "css",
    "tokens",
    "arabic",
    "open-source"
  ],
  "author": "Youssef Osama",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Youssef-osama33/palestine-ui.git"
  },
  "homepage": "https://palestine-ui.dev",
  "bugs": {
    "url": "https://github.com/Youssef-osama33/palestine-ui/issues"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.19.12",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ts-jest": "^29.4.10",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "directories": {
    "example": "examples"
  },
  "type": "commonjs"
}
